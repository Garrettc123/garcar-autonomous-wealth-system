# Garcar Autonomous Wealth System - Environment Configuration
# Copy to .env and fill in your actual keys

# AWS Configuration
AWS_REGION=us-west-2
AWS_ACCOUNT_ID=your-account-id
S3_BUCKET=garcar-revenue-data
KMS_KEY_ID=your-kms-key-id
LAMBDA_EXECUTION_ROLE_ARN=arn:aws:iam::your-account:role/garcar-lambda-execution-role

# Stripe Payment Processing
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_PRICE_ID=price_your_price_id  # Create $99/mo price in Stripe Dashboard
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Linear Task Management
LINEAR_API_KEY=lin_api_your_linear_key
LINEAR_TEAM_ID=your-team-uuid
LINEAR_REVENUE_LABEL=your-revenue-label-id

# Apollo Lead Generation
APOLLO_API_KEY=your_apollo_api_key

# AI/LLM API Keys
OPENAI_API_KEY=sk-your-openai-key  # For LangChain orchestration
# Or use Gemini instead:
# GOOGLE_API_KEY=your-gemini-key

# GitHub (for CI/CD secrets)
# Add these as GitHub Secrets in your repo settings:
# AWS_ACCESS_KEY_ID
# AWS_SECRET_ACCESS_KEY
# All of the above variables

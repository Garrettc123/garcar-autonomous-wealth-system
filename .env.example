# Garcar Autonomous Wealth System - Environment Configuration
# Copy to .env and fill in your actual keys

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=your-account-id
S3_BUCKET=garcar-revenue-data
KMS_KEY_ID=your-kms-key-id
LAMBDA_EXECUTION_ROLE_ARN=arn:aws:iam::your-account:role/garcar-lambda-execution-role

# Stripe Payment Processing (multi-product)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_PRICE_BASIC=price_basic_49_per_month       # Basic plan  $49/mo
STRIPE_PRICE_PRO=price_pro_99_per_month           # Pro plan    $99/mo
STRIPE_PRICE_ENTERPRISE=price_enterprise_299_per_month  # Enterprise $299/mo
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Linear Task Management
LINEAR_API_KEY=lin_api_your_linear_key
LINEAR_TEAM_ID=your-team-uuid
LINEAR_REVENUE_LABEL=your-revenue-label-id

# Apollo Lead Generation
APOLLO_API_KEY=your_apollo_api_key

# AI/LLM API Keys
OPENAI_API_KEY=sk-your-openai-key  # For LangChain orchestration
# Or use Gemini instead:
# GOOGLE_API_KEY=your-gemini-key

# AWS SES – Email Nurture Sequences
SES_SENDER_EMAIL=noreply@garcar.io   # Must be verified in SES

# Twilio – SMS Outreach
TWILIO_ACCOUNT_SID=ACyour_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+15005550006       # Twilio test number or verified sender
SMS_SCORE_THRESHOLD=0.75              # Minimum ML score to trigger SMS

# Dashboard API
DASHBOARD_API_KEY=your-secure-dashboard-api-key
DASHBOARD_URL=https://app.garcar.io/dashboard
UPGRADE_URL=https://app.garcar.io/upgrade
TRIAL_URL=https://app.garcar.io/trial
CALENDAR_URL=https://cal.garcar.io/enterprise
DASHBOARD_PORT=5000

# RLHF Agent
RLHF_LEARNING_RATE=0.05
RLHF_DISCOUNT_FACTOR=0.95

# GitHub (for CI/CD secrets)
# Add these as GitHub Secrets in your repo settings:
# AWS_ACCESS_KEY_ID
# AWS_SECRET_ACCESS_KEY
# All of the above variables
